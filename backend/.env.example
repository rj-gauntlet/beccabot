# BeccaBot Configuration
# Copy to .env and fill in values

# OpenAI API (for embeddings + chat - gpt-4o-mini for Q&A)
OPENAI_API_KEY=your_openai_key_here

# Documents lock – PIN to unlock Documents tab (Rebecca + admin). Leave empty for no lock.
# DOCUMENTS_PIN=1234

# Weather (optional - uses Open-Meteo by default, no key needed)
# Set OPENWEATHERMAP_API_KEY to use OpenWeatherMap instead
# OPENWEATHERMAP_API_KEY=your_key_here

# Gauntlet addresses (optional - override if different)
# HOUSING_ADDRESS=710 E 3rd Street, Austin, TX 78701
# OFFICE_ADDRESS=416 Congress Ave, Austin, TX 78701

# Rebecca's contact info for fallback messages
REBECCA_EMAIL=rebecca@example.com
REBECCA_CONTACT="Reach out to Rebecca at rebecca@example.com"

# Google Sheets (optional - catalog unanswerable questions by frequency)
# Share the sheet with the service account email from credentials.json
# GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
# GOOGLE_SHEET_ID=your_sheet_id

# Slack (optional - run python -m app.slack_bot for Slack integration)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
